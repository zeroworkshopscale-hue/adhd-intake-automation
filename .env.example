# ===========================================================================
# ADHD Intake Automation -- Environment variables (optional overrides)
# ===========================================================================
# Copy this file to ".env" to use it. ".env" is git-ignored.
#
# All configuration normally lives in config.yaml. These environment variables
# provide a way to override sensitive values without editing config.yaml
# (useful on shared machines or in CI/CD pipelines).
#
# The application does NOT load this file automatically. If you want to use
# environment variables, either:
#   a) Set them in your shell / Windows Environment Variables panel, OR
#   b) Add "python-dotenv" to requirements.txt and call load_dotenv() in main.py
# ===========================================================================

# OSCAR / KAI EMR
# Username and password are intentionally NOT stored in config.yaml --
# the app prompts for them at startup. You can pre-set them here for
# automated / headless testing only (never for production use).
# OSCAR_USERNAME=your_oscar_username
# OSCAR_PASSWORD=your_oscar_password

# OSCAR base URL (overrides oscar.base_url in config.yaml)
# OSCAR_BASE_URL=https://welcome.kai-oscar.com/oscar

# Google Sheets service account key (overrides sheets.service_account_file)
# GOOGLE_SERVICE_ACCOUNT_FILE=./secrets/google_service_account.json

# Google Sheets spreadsheet ID (overrides sheets.spreadsheet_id)
# GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here
